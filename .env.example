# Median Environment Configuration
# Copy this to .env and customize

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080                              # External port (NGINX)

# ── Paths ─────────────────────────────────────────────────────────────────────
UPLOAD_FOLDER=/app/downloads
BACKUP_FOLDER=/app/backups
WATCHED_FOLDER=/app/watched
LOG_FOLDER=/app/logs
DATABASE_PATH=/app/database/median.db

# ── Cleanup ───────────────────────────────────────────────────────────────────
CLEANUP_INTERVAL=15                    # Minutes until downloaded files are deleted

# ── Auto-update ───────────────────────────────────────────────────────────────
AUTO_UPDATE_INTERVAL=48                # Hours between yt-dlp/FFmpeg updates

# ── Downloads ─────────────────────────────────────────────────────────────────
DOWNLOAD_CHUNK_SIZE=5                  # MB — HTTP chunk size for downloads

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_RETENTION_DAYS=7

# ── Watched Folder ────────────────────────────────────────────────────────────
WATCHED_FOLDER_CHECK_INTERVAL=5       # Seconds between file checks

# ── Cover Settings ────────────────────────────────────────────────────────────
COVER_DEFAULT_RATIO=1:1
COVER_DEFAULT_RESOLUTION=medium
COVER_CACHE_ENABLED=true
COVER_CACHE_TTL=86400                 # 24 hours

# ── Blurry Background Padding ─────────────────────────────────────────────────
BLURRY_PADDING_ENABLED=true
BLURRY_PADDING_BLUR_RADIUS=40
BLURRY_PADDING_BLUR_SIGMA=2

# ── Concatenation ─────────────────────────────────────────────────────────────
CONCATENATION_VALIDATE_BEFORE=true
CONCATENATION_CREATE_CHAPTERS=true
FFMPEG_CHAPTERS_ENABLED=true
FFMPEG_CHAPTERS_FORMAT=id3

# ── Preview ───────────────────────────────────────────────────────────────────
PREVIEW_THUMBNAIL_SIZE=300x300
PREVIEW_CACHE_ENABLED=true

# ── Database ──────────────────────────────────────────────────────────────────
# (SQLite WAL mode auto-enabled, no config needed)
